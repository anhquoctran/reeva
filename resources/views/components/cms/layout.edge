<!DOCTYPE html>
<html lang="en-us">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
      {{ title || 'Reeva - Dashboard' }}
    </title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    @vite(['resources/css/app.css', 'resources/js/app.js'])
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans overflow-hidden">
    <div class="flex h-screen w-full">
      <!-- Sidebar -->
      <aside class="w-64 bg-white border-r border-gray-100 flex flex-col shadow-sm">
        <div class="p-6 h-16 border-b border-gray-50 flex items-center gap-3">
          <div class="w-8 h-8 bg-brand-600 rounded-lg flex items-center justify-center text-white font-bold shadow-md shadow-brand-100">R</div>
          <span class="text-xl font-bold tracking-tight text-gray-900">Reeva</span>
        </div>
        
        <nav class="flex-1 p-4 flex flex-col gap-1">
          <a href="{{ route('cms.dashboard') }}" 
             class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {{ request.url() === route('cms.dashboard') ? 'bg-brand-50 text-brand-700' : 'text-gray-600 hover:bg-gray-50' }}">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
            Home
          </a>
          
          <a href="{{ route('cms.versions.index') }}" 
             class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {{ request.url().startsWith(route('cms.versions.index')) ? 'bg-brand-50 text-brand-700' : 'text-gray-600 hover:bg-gray-50' }}">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 11h.01M7 15h.01M13 7h.01M13 11h.01M13 15h.01M17 7h.01M17 11h.01M17 15h.01M3 21h18M3 7a2 2 0 012-2h14a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"></path></svg>
            Versions
          </a>
          
          <a href="{{ route('cms.artifacts.index') }}" 
             class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {{ request.url().startsWith(route('cms.artifacts.index')) ? 'bg-brand-50 text-brand-700' : 'text-gray-600 hover:bg-gray-50' }}">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
            Artifacts
          </a>
          
          <a href="{{ route('cms.storage.index') }}" 
             class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {{ request.url().startsWith(route('cms.storage.index')) ? 'bg-brand-50 text-brand-700' : 'text-gray-600 hover:bg-gray-50' }}">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path></svg>
            Storage Providers
          </a>
          
          <a href="{{ route('cms.settings.index') }}" 
             class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {{ request.url().startsWith(route('cms.settings.index')) ? 'bg-brand-50 text-brand-700' : 'text-gray-600 hover:bg-gray-50' }}">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path></svg>
            System Settings
          </a>
          
          <a href="{{ route('cms.users.index') }}" 
             class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium {{ request.url().startsWith(route('cms.users.index')) ? 'bg-brand-50 text-brand-700' : 'text-gray-600 hover:bg-gray-50' }}">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
            Users
          </a>
        </nav>
        
        <!-- User Section -->
        <div class="p-4 border-t border-gray-50">
          <a href="{{ route('cms.profile.index') }}" class="flex items-center gap-3 mb-4 group p-2 rounded-xl hover:bg-gray-50 transition-all">
            <div class="w-10 h-10 rounded-full bg-brand-50 flex items-center justify-center text-brand-700 font-bold uppercase ring-2 ring-brand-100 flex-shrink-0 group-hover:scale-105 transition-transform">
              {{ auth.user.initials }}
            </div>
            <div class="flex-1 overflow-hidden">
               <p class="text-sm font-extrabold truncate text-gray-900">{{ auth.user.fullName || 'Administrator' }}</p>
               <p class="text-[10px] text-gray-400 font-medium truncate">{{ auth.user.email }}</p>
            </div>
          </a>
          
          <form action="{{ route('session.destroy') }}" method="POST" class="block">
            {{ csrfField() }}
            <button type="submit" class="w-full text-left flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-red-600 hover:bg-red-50 transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
              Logout
            </button>
          </form>
        </div>
      </aside>
      
      <!-- Content Area -->
      <main class="flex-1 overflow-y-auto w-full max-w-none bg-gray-50">
        <div class="p-8">
          @include('partials/toasts')
          {{{ await $slots.main() }}}
        </div>
      </main>
    </div>
  </body>
</html>
